/* 1. Basic Setup */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif; /* Instruction #4 */
}

body {
    background-color: #f3f0e7; /* Figma jaisa beige color */
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* 2. Navbar Styling */
.navbar {
    width: 100%;
    max-width: 1200px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    margin-bottom: 50px;
}

.nav-links a {
    text-decoration: none;
    color: #000;
    margin: 0 15px;
    font-weight: 500;
}

.contact-btn {
    padding: 10px 25px;
    border-radius: 25px;
    border: 1px solid #000;
    background: transparent;
    cursor: pointer;
}

/* 3. Card Styling */
.main-container {
    display: flex;
    justify-content: center;
    width: 100%;
}

.card {
    background: #fff;
    padding: 15px;
    border-radius: 15px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.card img {
    width: 100%;
    border-radius: 10px;
    display: block;
}

.content {
    padding: 20px 10px;
}

.content h2 {
    margin-bottom: 10px;
    font-size: 24px;
}

/* 4. Hover Animation (Instruction #8 - 15 Marks) */
.btn {
    margin-top: 15px;
    padding: 12px 25px;
    background-color: #000;
    color: #fff;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: transform 0.3s ease, background-color 0.3s ease; /* Smooth transition */
}

.btn:hover {
    transform: scale(1.1); /* Button grow hoga */
    background-color: #444; /* Color light shade mein jayega */
}

/* 5. Responsive Design (Instruction #5 - 20 Marks) */
@media (max-width: 768px) {
    body {
        padding: 10px;
    }
    .navbar {
        flex-direction: column;
        gap: 15px;
    }
    .card {
        max-width: 100%;
    }
}
